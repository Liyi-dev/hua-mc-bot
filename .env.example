# Minecraft 服务器连接
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=HuaBot

# 认证方式："offline" | "mojang" | "microsoft"
# 本地/离线服务器请使用 "offline"
MC_AUTH=offline

# 游戏版本（false = 自动检测服务器版本）
MC_VERSION=false

# 聊天指令前缀
COMMAND_PREFIX=!

# 断线后自动重连
RECONNECT_ENABLED=true
RECONNECT_MAX_ATTEMPTS=10    # -1 表示无限重试
RECONNECT_BASE_DELAY_MS=1000 # 首次重连延迟（毫秒）
RECONNECT_MAX_DELAY_MS=60000 # 最大重连延迟上限（毫秒）

# MCP Agent 接口（供外部 AI 项目调用）
MCP_ENABLED=true
MCP_HOST=127.0.0.1
MCP_PORT=3100
# 传输方式：http（推荐，远程 AI 调用）| stdio（Cursor 子进程）| both
MCP_TRANSPORT=http
