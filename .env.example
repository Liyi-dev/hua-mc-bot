# Minecraft server connection
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=HuaBot

# Authentication: "offline" | "mojang" | "microsoft"
# Use "offline" for local/cracked servers
MC_AUTH=offline

# Game version (false = auto-detect from server)
MC_VERSION=false

# Chat command prefix
COMMAND_PREFIX=!

# Auto-reconnect on disconnect
RECONNECT_ENABLED=true
RECONNECT_MAX_ATTEMPTS=10    # -1 = infinite retries
RECONNECT_BASE_DELAY_MS=1000 # starting delay in ms
RECONNECT_MAX_DELAY_MS=60000 # maximum delay cap in ms
